---
/**
 * Uses Page (Ahora adaptada para Certificaciones)
 * 
 * Documents the tools, technologies, and environment used in the development workflow.
 * Provides transparency about the technical stack and helps other engineers discover
 * useful tools while understanding the technical context.
 * 
 * Route: /uses
 * 
 * @page
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import { getCollection } from 'astro:content';
import { pagesConfig } from '../pages.config';

/**
 * Queries all uses entries from the content collection
 */
const allUses = await getCollection('uses');

/**
 * Sorts uses entries by custom order field
 */
const sortedUses = allUses.sort((a, b) => a.data.order - b.data.order);

/**
 * Groups uses entries by category
 */
const groupedByCategory = sortedUses.reduce((acc, entry) => {
  const category = entry.data.category;
  if (!acc[category]) {
    acc[category] = [];
  }
  acc[category].push(entry);
  return acc;
}, {} as Record<string, typeof sortedUses>);

/**
 * Category metadata for display
 * Actualizado para soportar las categorías de certificaciones.
 */
const categoryInfo: Record<string, { title: string; description: string }> = {
  backend: { title: 'Backend Development', description: 'Certificaciones enfocadas en arquitectura, APIs y lógica de servidor' },
  cloud: { title: 'Cloud & DevOps', description: 'Certificaciones en infraestructura, despliegue y nube' },
  frontend: { title: 'Frontend Development', description: 'Certificaciones en interfaces y experiencia de usuario' },
  ai: { title: 'Inteligencia Artificial', description: 'Certificaciones en Machine Learning y Análisis de Datos' },
  tools: { title: 'Herramientas', description: 'Software y aplicaciones' },
  stack: { title: 'Tech Stack', description: 'Tecnologías y frameworks' },
  environment: { title: 'Environment', description: 'Entorno de desarrollo' },
};

/**
 * Defines the display order for categories
 * Incluimos las nuevas categorías de certificaciones.
 */
const categoryOrder: string[] = ['backend', 'cloud', 'frontend', 'ai', 'tools', 'stack', 'environment'];
---

<BaseLayout>
  <SEO 
    slot="head"
    title={pagesConfig.uses.title}
    description={pagesConfig.uses.description}
    type="website"
  />

  <main class="page-container">
    <header class="page-header">
      <h1 class="page-title">{pagesConfig.uses.heading}</h1>
      <p class="page-intro">
        {pagesConfig.uses.intro}
      </p>
    </header>

    {categoryOrder.map((categoryKey) => {
      const entries = groupedByCategory[categoryKey];
      if (!entries || entries.length === 0) return null;

      // Si la categoría no está en categoryInfo, usamos valores por defecto
      const info = categoryInfo[categoryKey] || { title: categoryKey, description: '' };

      return (
        <section class="category-section">
          <div class="category-header">
            <h2>{info.title}</h2>
            <p class="category-description">{info.description}</p>
          </div>

          <div class="items-list">
            {entries.map((entry) => (
              entry.data.items.map((item: any) => (
                <div class="item">
                  <h3 class="item-name">
                    {item.url ? (
                      <a href={item.url} target="_blank" rel="noopener noreferrer">
                        {item.name}
                        <span class="external-link-icon" aria-hidden="true">↗</span>
                      </a>
                    ) : (
                      item.name
                    )}
                  </h3>
                  
                  {/* Nueva sección para mostrar Emisor y Fecha */}
                  {(item.issuer || item.date) && (
                    <p class="item-meta">
                      {item.issuer} {item.issuer && item.date && ' • '} {item.date}
                    </p>
                  )}

                  <p class="item-description">{item.description}</p>
                </div>
              ))
            ))}
          </div>
        </section>
      );
    })}

    {sortedUses.length === 0 && (
      <p class="empty-state">Aún no hay certificaciones documentadas.</p>
    )}
  </main>

  <style>
    .category-section {
      margin-bottom: 4rem;
    }

    .category-section:last-of-type {
      margin-bottom: 2rem;
    }

    .category-header {
      margin-bottom: 2rem;
      padding-bottom: 0.75rem;
      border-bottom: 2px solid var(--color-border);
    }

    .category-header h2 {
      font-size: 1.75rem;
      margin-bottom: 0.5rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      text-transform: capitalize;
    }

    .category-description {
      font-size: 1rem;
      color: var(--color-text-secondary);
      margin: 0;
    }

    .items-list {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }

    .item-name {
      font-size: 1.25rem;
      margin-bottom: 0.25rem;
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    .item-name a {
      color: var(--color-text);
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      transition: color 0.2s ease;
    }

    .item-name a:hover {
      color: var(--color-accent);
    }

    .external-link-icon {
      font-size: 0.875rem;
      opacity: 0.6;
    }

    /* Estilos para el emisor y la fecha */
    .item-meta {
      font-size: 0.9rem;
      color: var(--color-text-secondary);
      opacity: 0.8;
      margin-top: 0;
      margin-bottom: 0.5rem;
      font-weight: 500;
    }

    .item-description {
      font-size: 1rem;
      line-height: 1.6;
      color: var(--color-text-secondary);
      margin: 0;
    }

    @media (max-width: 768px) {
      .category-header h2 {
        font-size: 1.5rem;
      }

      .item-name {
        font-size: 1.125rem;
      }

      .items-list {
        gap: 1.5rem;
      }
    }
  </style>
</BaseLayout>
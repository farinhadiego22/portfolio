---
/**
 * Contact Page
 * 
 * Minimal, intentional contact page with clear visual hierarchy and zone-based layout.
 * Prioritizes direct contact methods (email, phone) while providing secondary social links.
 * 
 * Layout Structure:
 * - Zone 1 (Primary): Email address and Phone number with context
 * - Zone 2 (Secondary): Social media links (only shown if configured)
 * 
 * Features:
 * - Clean, distraction-free design
 * - Large, prominent contact links
 * - Phone number section added
 * - Automatic filtering of configured social links
 * - Responsive layout
 * - Clear visual hierarchy
 * 
 * Route: /contact
 * 
 * @page
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from '../components/SEO.astro';
import { siteConfig } from '../config';
import { pagesConfig } from '../pages.config';

/**
 * Filters and formats social links from site configuration
 */
const socialLinks = Object.entries(siteConfig.social)
  .filter(([_, url]) => url)
  .map(([platform, url]) => ({
    platform: platform.charAt(0).toUpperCase() + platform.slice(1),
    url
  }));

// Puedes modificar este número o importarlo desde tu siteConfig si lo prefieres
const phoneNumber = "+56 9 8359 8865";
const phoneLink = phoneNumber.replace(/\s+/g, ''); // Remueve espacios para el href="tel:"
---

<BaseLayout>
  <SEO 
    slot="head"
    title={pagesConfig.contact.title}
    description={pagesConfig.contact.description}
    type="website"
  />

  <main class="contact-page">
    <!-- Zone 1: Primary Intent -->
    <section class="primary-zone">
      <h1>{pagesConfig.contact.heading}</h1>
      <p class="context">
        Leo todos los mensajes. Recibirás una respuesta a la brevedad.
      </p>

      <div class="contact-methods">
        <!-- Correo Electrónico -->
        <div class="method-block">
          <span class="method-label">Correo electrónico</span>
          <a href={`mailto:${siteConfig.author.email}`} class="method-link">
            {siteConfig.author.email}
          </a>
        </div>

        <!-- Teléfono -->
        <div class="method-block">
          <span class="method-label">Teléfono / WhatsApp</span>
          <a href={`tel:${phoneLink}`} class="method-link">
            {phoneNumber}
          </a>
        </div>
      </div>
    </section>

    <!-- Zone 2: Secondary (Social) -->
    {socialLinks.length > 0 && (
      <section class="secondary-zone">
        <h2>Por otros medios</h2>
        <div class="social-links">
          {socialLinks.map((link, index) => (
            <>
              <a href={link.url} target="_blank" rel="noopener noreferrer">
                {link.platform}
              </a>
              {index < socialLinks.length - 1 && <span class="separator">·</span>}
            </>
          ))}
        </div>
      </section>
    )}
  </main>

  <style>
    .contact-page {
      max-width: 700px;
      margin: 0 auto;
      padding: 3rem 1.5rem 8rem;
    }

    .primary-zone {
      margin-bottom: 4rem;
    }

    .primary-zone h1 {
      font-size: 2rem;
      font-weight: 500;
      color: var(--color-text);
      margin-bottom: 1rem;
      letter-spacing: 0.01em;
    }

    .context {
      font-size: 1rem;
      color: var(--color-text-muted);
      line-height: 1.6;
      margin-bottom: 3rem;
    }

    .contact-methods {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
    }

    .method-block {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .method-label {
      font-size: 0.8125rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-text-muted);
    }

    .method-link {
      display: inline-block;
      font-size: clamp(1.5rem, 5vw, 2.25rem);
      font-weight: 300;
      color: var(--color-text);
      text-decoration: none;
      letter-spacing: -0.02em;
      transition: color 0.2s ease, transform 0.2s ease;
      transform-origin: left;
    }

    .method-link:hover {
      color: var(--color-text-secondary);
      transform: translateX(4px);
    }

    .secondary-zone {
      padding-top: 3rem;
      border-top: 1px solid var(--color-border);
    }

    .secondary-zone h2 {
      font-size: 0.8125rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--color-text-muted);
      margin-bottom: 1rem;
    }

    .social-links {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.5rem;
    }

    .social-links a {
      color: var(--color-text-secondary);
      text-decoration: none;
      font-size: 1rem;
      transition: color 0.2s ease;
    }

    .social-links a:hover {
      color: var(--color-text);
    }

    .separator {
      color: var(--color-text-muted);
      user-select: none;
    }

    @media (max-width: 640px) {
      .contact-page {
        padding: 4rem 1rem 6rem;
      }

      .primary-zone {
        margin-bottom: 3rem;
      }

      .primary-zone h1 {
        font-size: 1rem;
      }
      
      .contact-methods {
        gap: 2rem;
      }
    }
  </style>
</BaseLayout>
---
/**
 * Página de Índice de Proyectos
 * 
 * Enumera todos los proyectos como casos de estudio con resúmenes de impacto. 
 * Los proyectos se muestran en un orden priorizado: el orden personalizado (si se especifica) 
 * tiene precedencia; de lo contrario, se ordenan por año (el más reciente primero). 
 * Los proyectos destacados se resaltan.
 * 
 * Características:
 * - Consulta todos los proyectos de la colección de contenido
 * - Orden inteligente: orden personalizado → año (descendente)
 * - Muestra estadísticas de conteo total y proyectos destacados
 * - Utiliza el componente ProjectCard para una presentación consistente
 * - Optimización SEO
 * - Manejo de estado vacío
 * 
 * Ruta: /projects
 * 
 * @page
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import SEO from '../../components/SEO.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import PageStats from '../../components/PageStats.astro';
import { getCollection } from 'astro:content';
import { pagesConfig } from '../../pages.config';

/**
 * Obtiene todos los proyectos de la colección de contenido
 */
const allProjects = await getCollection('projects');

/**
 * Ordena los proyectos con priorización inteligente
 * 
 * Lógica de ordenamiento:
 * 1. Si ambos proyectos tienen un campo 'order', se ordena por ese número (ascendente)
 * 2. Los proyectos con el campo 'order' tienen prioridad sobre los que no lo tienen
 * 3. Los proyectos sin 'order' se ordenan por año (descendente - los más nuevos primero)
 * 
 * Esto permite una curación manual de proyectos destacados manteniendo el
 * orden cronológico para los demás.
 */
const sortedProjects = allProjects.sort((a, b) => {
  // Si ambos tienen campo de orden, ordenar por ese número
  if (a.data.order !== undefined && b.data.order !== undefined) {
    return a.data.order - b.data.order;
  }
  // Si solo uno tiene orden, priorizarlo
  if (a.data.order !== undefined) return -1;
  if (b.data.order !== undefined) return 1;
  // De lo contrario, ordenar por año (descendente)
  return b.data.year - a.data.year;
});

/**
 * Conteo total de proyectos para la visualización de estadísticas
 */
const totalProjects = sortedProjects.length;

/**
 * Conteo de proyectos destacados para la visualización de estadísticas
 */
const featuredCount = sortedProjects.filter(p => p.data.featured).length;
---

<BaseLayout>
  <SEO 
    slot="head"
    title={pagesConfig.projects.title}
    description={pagesConfig.projects.description}
    type="website"
  />

  <main class="page-container">
    <header class="page-header">
      <h1 class="page-title">{pagesConfig.projects.heading}</h1>
      <p class="page-intro">
        {pagesConfig.projects.intro}
      </p>
      <PageStats text={`${totalProjects} proyectos · ${featuredCount} destacados`} />
    </header>

    {sortedProjects.length > 0 ? (
      <div class="card-list">
        {sortedProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            slug={project.id}
            outcomeSummary={project.data.outcomeSummary}
            role={project.data.role}
            year={project.data.year}
            techStack={project.data.techStack}
            featured={project.data.featured}
            status={project.data.status}
          />
        ))}
      </div>
    ) : (
      <p class="empty-state">No hay proyectos disponibles por el momento.</p>
    )}
  </main>
</BaseLayout>